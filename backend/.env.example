# Copy to .env and update values if needed

# Server port for the backend
PORT=4000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/matchhire

# JWT secrets used for access and refresh tokens
JWT_SECRET=replace_with_a_strong_secret
JWT_REFRESH_SECRET=replace_with_a_strong_refresh_secret

# Optional AI key for Gemini / Google generative AI features
GEMINI_API_KEY=your_gemini_api_key_here

# Optional fallback keys used by the parser if GEMINI_API_KEY is not available
# GEN_API_KEY=your_google_gen_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
